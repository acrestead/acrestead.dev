---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_TITLE}</p>
	<p class="tagline">Homesteading × technology.</p>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0.25em 0;
	}
	.tagline {
		font-size: 0.9em;
		color: rgb(var(--gray));
		font-style: italic;
	}
</style>
