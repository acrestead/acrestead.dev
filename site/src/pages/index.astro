---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} — Homesteading × Technology`}
			description={SITE_DESCRIPTION}
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>{SITE_TAGLINE}</h1>
			<p>
				Practical notes from the overlap of two interests: working a piece of land, and the
				software that helps. Garden plans, irrigation, weather data, homelab setups, and the
				occasional small tool I wrote to scratch a homestead-shaped itch.
			</p>
			<p>
				Start with the <a href="/blog/">latest posts</a>, or read more <a href="/about/">about the project</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
